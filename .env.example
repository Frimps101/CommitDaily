# ---------------------------------------------------------------------------
# Database (Supabase or Neon). DATABASE_URL is pooled; DIRECT_URL is direct
# (used by Prisma migrate). For local Postgres both can be the same.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/commitdaily?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/commitdaily?schema=public"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# Generate AUTH_SECRET with: npx auth secret  (or: openssl rand -base64 32)
# ---------------------------------------------------------------------------
AUTH_SECRET="replace-me"
AUTH_URL="http://localhost:3000"

# GitHub OAuth App credentials.
# Create at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID="replace-me"
AUTH_GITHUB_SECRET="replace-me"

# ---------------------------------------------------------------------------
# Token encryption at rest. 32-byte key, base64-encoded.
# Generate with: openssl rand -base64 32
# ---------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY="replace-me-32-byte-base64-key"

# ---------------------------------------------------------------------------
# Web Push (VAPID). Generate with: npm run keys:vapid
# ---------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY="replace-me"
VAPID_PRIVATE_KEY="replace-me"
VAPID_SUBJECT="mailto:you@example.com"

# ---------------------------------------------------------------------------
# Cron heartbeat protection. The scheduled job must send:
#   Authorization: Bearer <CRON_SECRET>
# Vercel Cron sends this automatically when CRON_SECRET is set in the project.
# ---------------------------------------------------------------------------
CRON_SECRET="replace-me"
